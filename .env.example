# The Forecaster — environment template.
# Copy to ".env" and fill in. EVERY key is OPTIONAL: with none set, the notebook
# runs fully offline on deterministic stubs (seeded synthetic data + stub LLMs).

# --- Live market data (optional). Falls back Alpaca -> yfinance -> seeded GBM. ---
ALPACA_API_KEY=
ALPACA_SECRET_KEY=

# --- Hugging Face token (optional) — only needed to download BGE embedding /
#     cross-encoder reranker weights for real RAG. Either name is accepted. ---
HUGGINGFACE_TOKEN=
HF_TOKEN=

# --- Run mode (optional) — set to 1 for a fast, deterministic, offline-graceful
#     pass (collapses roles onto one model, shrinks samples; full cycle < 1 min). ---
FORECASTER_FAST=0

# --- Local inference tuning (optional) — parallel Ollama requests. ---
OLLAMA_NUM_PARALLEL=1

# --- macOS OpenMP workaround (optional) — set to TRUE only if torch/OpenMP
#     raises a duplicate-libomp error. ---
KMP_DUPLICATE_LIB_OK=
